{
  "name": "coco-lang",
  "version": "0.1.0",
  "description": "Coco language prototype: Bun-native lexer, docs, tutorial, and static project page.",
  "type": "module",
  "private": true,
  "bin": {
    "coco": "./src/cli.ts",
    "cococ": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./src/runtime/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/cli.ts ./src/runtime/index.ts --outdir dist --target bun --format esm",
    "check": "tsc --noEmit",
    "install:global": "bun scripts/install-global.ts",
    "test": "bun test",
    "test:page": "node tests/page-smoke.mjs",
    "lint": "bun run check",
    "dev:page": "bunx serve page"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright": "latest",
    "serve": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
