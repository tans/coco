age = 20
active = true
users = ["Tom", "Jerry"]

if age >= 18 and active
  print "adult"
elif age >= 13
  print "teen"
else
  print "child"

for index in 1..3
  print "index {index}"

for name in users
  label = name |> describeUser
  print label

match age
  20 -> print "twenty"
  _ -> print "other age"

while active
  break

fn describeUser name
  return "user {name}"
